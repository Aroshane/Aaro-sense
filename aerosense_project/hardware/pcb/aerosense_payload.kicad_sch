  ; Pin mapping (key signals only — remainder tied to GND or +3.3V):
  ; Pin 1  = 3.3V out (to sensor rail)
  ; Pin 2  = 5V in (from BEC via J1)
  ; Pin 3  = GPIO2 / SDA1 (I2C data — BME680, ADS1115)
  ; Pin 5  = GPIO3 / SCL1 (I2C clock)
  ; Pin 6  = GND
  ; Pin 8  = GPIO14 / UART0 TX → SDS011 RX
  ; Pin 10 = GPIO15 / UART0 RX ← SDS011 TX
  ; Pin 18 = GPIO24 → LoRa DIO0
  ; Pin 19 = GPIO10 / SPI0 MOSI → LoRa
  ; Pin 21 = GPIO9  / SPI0 MISO ← LoRa
  ; Pin 22 = GPIO25 → LoRa RESET
  ; Pin 23 = GPIO11 / SPI0 SCLK
  ; Pin 24 = GPIO8  / SPI0 CE0 → LoRa NSS
  ; Pin 33 = GPIO13 / UART1 RX ← GPS TX
  ; Pin 36 = GPIO16 / UART1 TX → GPS RX

